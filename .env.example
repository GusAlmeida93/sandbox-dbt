# ============================================================================
# sandbox-dbt environment -- copy to .env and adjust if needed:
#     cp .env.example .env
#
# .env is the single source of configuration. It is read by:
#   * docker compose (variable interpolation in docker-compose.yml)
#   * the Makefile (-include .env / export)
#   * python scripts and notebooks (python-dotenv)
#
# All credentials here are intentionally toy values: everything binds to
# 127.0.0.1 only, and this is a throwaway local learning warehouse.
# ============================================================================

# --- Postgres service (the warehouse) ---------------------------------------
POSTGRES_USER=dbt
POSTGRES_PASSWORD=dbt
POSTGRES_DB=jaffle_shop

# --- Host-published ports (all bound to 127.0.0.1) --------------------------
# NOTE: keep values free of inline comments/trailing spaces -- this file is
# parsed by docker compose AND by make, which treat them differently.
# postgres (psql / IDE access from the host):
POSTGRES_PORT=5432
# web UI to browse the database:
ADMINER_PORT=8080
# dbt docs serve:
DBT_DOCS_PORT=8081
# JupyterLab:
JUPYTER_PORT=8888

# --- JupyterLab login token -------------------------------------------------
# Open http://localhost:8888/?token=<JUPYTER_TOKEN>
JUPYTER_TOKEN=dbt

# --- dbt connection (host mode) ---------------------------------------------
# These feed the env_var() calls in jaffle_shop/profiles.yml when you run dbt
# ON THE HOST (hybrid mode). Inside Docker, docker-compose.yml overrides
# DBT_HOST=postgres and DBT_PORT=5432 -- the same warehouse seen from inside
# the compose network.
#
# NOTE: if you change POSTGRES_PORT above, change DBT_PORT to match. They are
# the same port seen from two sides (container publish vs. host client).
DBT_HOST=localhost
DBT_PORT=5432
DBT_USER=dbt
DBT_PASSWORD=dbt
DBT_DBNAME=jaffle_shop

# --- dbt behavior -----------------------------------------------------------
# Quieter, faster, offline-friendly.
DBT_SEND_ANONYMOUS_USAGE_STATS=false
